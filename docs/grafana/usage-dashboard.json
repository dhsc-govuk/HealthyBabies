{
  "__inputs": [
    {
      "name": "DS_AZURE_MONITOR",
      "label": "Azure Monitor",
      "description": "",
      "type": "datasource",
      "pluginId": "grafana-azure-monitor-datasource",
      "pluginName": "Azure Monitor"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "datasource",
      "id": "grafana-azure-monitor-datasource",
      "name": "Azure Monitor",
      "version": "1.0.0"
    },
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Form journey usage analytics — sessions, submission rates, funnel drop-off. Audience: business team.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["family-hubs", "usage"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "", "value": "" },
        "description": "Full Azure resource URI — /subscriptions/{subId}/resourceGroups/{rg}/providers/microsoft.insights/components/{name}",
        "hide": 0,
        "label": "App Insights Resource URI",
        "name": "appinsights_resource",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Family Hubs — Usage",
  "uid": "fh-usage-v1",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Form Journey",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Sessions Started",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "customEvents\n| where $__timeFilter(timestamp)\n| where name == 'form_started'\n| count",
            "resources": ["${appinsights_resource}"],
            "resultFormat": "table"
          },
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Forms Submitted",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "customEvents\n| where $__timeFilter(timestamp)\n| where name == 'form_submitted'\n| count",
            "resources": ["${appinsights_resource}"],
            "resultFormat": "table"
          },
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 75 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Submission Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "let started = toscalar(customEvents | where $__timeFilter(timestamp) | where name == 'form_started' | count);\nlet submitted = toscalar(customEvents | where $__timeFilter(timestamp) | where name == 'form_submitted' | count);\nprint rate = iif(started > 0, round(todouble(submitted) / todouble(started) * 100, 1), 0.0)",
            "resources": ["${appinsights_resource}"],
            "resultFormat": "table"
          },
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Abandonments",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "customEvents\n| where $__timeFilter(timestamp)\n| where name == 'form_abandoned'\n| count",
            "resources": ["${appinsights_resource}"],
            "resultFormat": "table"
          },
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 5 },
      "id": 6,
      "options": {
        "barRadius": 0,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "title": "Form Funnel",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "let order = datatable(name:string, sort_order:int)[\n  'form_started', 1,\n  'form_section_completed', 2,\n  'form_review_reached', 3,\n  'form_submit_attempted', 4,\n  'form_submitted', 5,\n  'form_abandoned', 6\n];\ncustomEvents\n| where $__timeFilter(timestamp)\n| where name in ('form_started','form_section_completed','form_review_reached','form_submit_attempted','form_submitted','form_abandoned')\n| summarize count = count() by name\n| join kind=leftouter order on name\n| order by sort_order asc\n| project name, count",
            "resources": ["${appinsights_resource}"],
            "resultFormat": "table"
          },
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 5 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Form Events Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "customEvents\n| where $__timeFilter(timestamp)\n| where name in ('form_started','form_submitted','form_abandoned')\n| summarize count() by name, bin(timestamp, 1h)",
            "resources": ["${appinsights_resource}"],
            "resultFormat": "time_series"
          },
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 8,
      "title": "All Events",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "count_" },
            "properties": [{ "id": "displayName", "value": "Count" }, { "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "name" },
            "properties": [{ "id": "displayName", "value": "Event" }, { "id": "custom.width", "value": 260 }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "id": 9,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "title": "Event Summary",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "${DS_AZURE_MONITOR}" },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "customEvents\n| where $__timeFilter(timestamp)\n| summarize count() by name\n| order by count_ desc",
            "resources": ["${appinsights_resource}"],
            "resultFormat": "table"
          },
          "refId": "A"
        }
      ]
    }
  ]
}